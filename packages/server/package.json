{
  "name": "@loom/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build --workspace @loom/core && tsc -p tsconfig.json",
    "dev": "npm run build && node dist/launch.js --api-only --port 5174 --no-open",
    "typecheck": "npm run build --workspace @loom/core && tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "pretest": "npm run build --workspace @loom/core",
    "test": "vitest run"
  },
  "dependencies": {
    "@loom/core": "0.0.0",
    "@fastify/static": "^9.1.3",
    "fastify": "^5.10.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {}
}
