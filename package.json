{
  "name": "continuity-loom",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run build && node packages/server/dist/launch.js",
    "typecheck": "node scripts/run-workspaces-if-present.mjs typecheck",
    "lint": "npm run build --workspace @loom/core && eslint . && node scripts/run-workspaces-if-present.mjs lint",
    "test": "npm run build --workspace @loom/core && vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild": true
  }
}
