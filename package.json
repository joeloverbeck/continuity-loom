{
  "name": "continuity-loom",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run build && node packages/server/dist/launch.js",
    "typecheck": "node scripts/run-workspaces-if-present.mjs typecheck",
    "lint": "npm run build --workspace @loom/core && eslint . && node scripts/run-workspaces-if-present.mjs lint",
    "test": "npm run build --workspace @loom/core && vitest run",
    "test:coverage:core": "npm run build --workspace @loom/core && vitest run --coverage packages/core",
    "mutation:prose": "stryker run stryker.prose.config.mjs",
    "mutation:ideation": "stryker run stryker.ideation.config.mjs",
    "mutation:validation": "stryker run stryker.validation.config.mjs",
    "mutation:core": "node scripts/robustness/run-core-mutation.mjs",
    "mutation:gate": "node scripts/robustness/mutation-gate.mjs",
    "mutation:changed": "node scripts/robustness/mutation-scope.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fast-check/vitest": "0.4.1",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/typescript-checker": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "^10.5.0",
    "fast-check": "4.8.0",
    "prettier": "^3.8.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild": true
  }
}
