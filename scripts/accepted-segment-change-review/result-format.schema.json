{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://continuity-loom.local/schemas/accepted-segment-change-review-result.v1.json",
  "title": "Accepted-Segment Change Review evaluated comparison",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "protocolId",
    "issueClosureIsGo",
    "requests",
    "aggregate",
    "deterministicFloorsPassed",
    "stewardReceipt"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "protocolId": { "type": "string", "minLength": 1 },
    "issueClosureIsGo": { "const": false },
    "requests": {
      "type": "array",
      "maxItems": 16,
      "items": { "$ref": "#/$defs/requestResult" }
    },
    "aggregate": { "$ref": "#/$defs/aggregate" },
    "deterministicFloorsPassed": { "type": "boolean" },
    "stewardReceipt": { "$ref": "#/$defs/stewardReceipt" }
  },
  "$defs": {
    "nonnegativeNumber": { "type": "number", "minimum": 0 },
    "ratio": { "type": "number", "minimum": 0, "maximum": 1 },
    "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "stringArray": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "requestResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schemaVersion",
        "requestId",
        "requestOrdinal",
        "caseId",
        "workflow",
        "provenance",
        "status",
        "failure",
        "sourceAccounting",
        "findings",
        "coverage",
        "requestPolicy",
        "writes",
        "measurements",
        "metrics",
        "floors"
      ],
      "properties": {
        "schemaVersion": { "const": 1 },
        "requestId": { "type": "string", "minLength": 1 },
        "requestOrdinal": { "type": "integer", "minimum": 1, "maximum": 16 },
        "caseId": { "type": "string", "minLength": 1 },
        "workflow": { "enum": ["old", "new"] },
        "provenance": { "$ref": "#/$defs/provenance" },
        "status": { "enum": ["completed", "malformed", "failed"] },
        "failure": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/failure" }
          ]
        },
        "sourceAccounting": { "$ref": "#/$defs/sourceAccounting" },
        "findings": {
          "type": "array",
          "items": { "$ref": "#/$defs/finding" }
        },
        "coverage": {
          "type": "array",
          "items": { "$ref": "#/$defs/coverageRow" }
        },
        "requestPolicy": { "$ref": "#/$defs/requestPolicy" },
        "writes": { "$ref": "#/$defs/writes" },
        "measurements": { "$ref": "#/$defs/measurements" },
        "metrics": { "$ref": "#/$defs/metrics" },
        "floors": { "$ref": "#/$defs/floors" }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract",
        "model",
        "settings",
        "segmentSelection",
        "recordScope",
        "startedAt",
        "completedAt",
        "sourceFingerprint",
        "promptSha256"
      ],
      "properties": {
        "contract": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "settings": {
          "type": "object",
          "additionalProperties": false,
          "required": ["temperature", "maxOutputTokens", "topP"],
          "properties": {
            "temperature": { "$ref": "#/$defs/nonnegativeNumber" },
            "maxOutputTokens": { "$ref": "#/$defs/nonnegativeNumber" },
            "topP": { "$ref": "#/$defs/nonnegativeNumber" }
          }
        },
        "segmentSelection": { "const": "latest" },
        "recordScope": { "enum": ["active_working_set", "whole_project"] },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "sourceFingerprint": { "$ref": "#/$defs/sha256" },
        "promptSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "message"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "sourceAccounting": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acceptedSegmentId",
        "acceptedSegmentSequence",
        "generationBriefFieldCount",
        "activeWorkingSetRecordIds",
        "wholeProjectRecordIds",
        "evidenceKeys",
        "contrastKeys",
        "secretRecordIds"
      ],
      "properties": {
        "acceptedSegmentId": { "type": "string", "minLength": 1 },
        "acceptedSegmentSequence": { "type": "integer", "minimum": 0 },
        "generationBriefFieldCount": { "const": 19 },
        "activeWorkingSetRecordIds": { "$ref": "#/$defs/stringArray" },
        "wholeProjectRecordIds": { "$ref": "#/$defs/stringArray" },
        "evidenceKeys": { "$ref": "#/$defs/stringArray" },
        "contrastKeys": { "$ref": "#/$defs/stringArray" },
        "secretRecordIds": { "$ref": "#/$defs/stringArray" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "findingId",
        "disposition",
        "evidenceKeys",
        "contrastKeys",
        "epistemicStatus",
        "retentionHorizon",
        "invented"
      ],
      "properties": {
        "findingId": { "type": "string", "minLength": 1 },
        "disposition": { "enum": ["found", "uncertain"] },
        "evidenceKeys": { "$ref": "#/$defs/stringArray" },
        "contrastKeys": { "$ref": "#/$defs/stringArray" },
        "epistemicStatus": {
          "enum": ["established change", "interpretation requiring author judgment"]
        },
        "retentionHorizon": {
          "enum": [
            "durable record candidate",
            "next-brief-only",
            "no storage",
            "author decision required"
          ]
        },
        "invented": { "type": "boolean" }
      }
    },
    "coverageRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "status", "reason"],
      "properties": {
        "dimension": { "type": "string", "minLength": 1 },
        "status": {
          "enum": ["changes found", "checked - no relevant change", "uncertain"]
        },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "requestPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["retryCount", "fallbackUsed", "repairCallUsed", "substitutionUsed"],
      "properties": {
        "retryCount": { "$ref": "#/$defs/nonnegativeNumber" },
        "fallbackUsed": { "type": "boolean" },
        "repairCallUsed": { "type": "boolean" },
        "substitutionUsed": { "type": "boolean" }
      }
    },
    "writes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["automatic", "projectStore"],
      "properties": {
        "automatic": { "$ref": "#/$defs/nonnegativeNumber" },
        "projectStore": { "$ref": "#/$defs/nonnegativeNumber" }
      }
    },
    "measurements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewTimeMs",
        "promptCharacters",
        "promptTokensEstimate",
        "latencyMs",
        "inputTokens",
        "outputTokens",
        "costUsd"
      ],
      "properties": {
        "reviewTimeMs": { "$ref": "#/$defs/nonnegativeNumber" },
        "promptCharacters": { "$ref": "#/$defs/nonnegativeNumber" },
        "promptTokensEstimate": { "$ref": "#/$defs/nonnegativeNumber" },
        "latencyMs": { "$ref": "#/$defs/nonnegativeNumber" },
        "inputTokens": { "$ref": "#/$defs/nonnegativeNumber" },
        "outputTokens": { "$ref": "#/$defs/nonnegativeNumber" },
        "costUsd": { "$ref": "#/$defs/nonnegativeNumber" }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recall",
        "precision",
        "retentionClassification",
        "invention",
        "empty",
        "malformed",
        "coverage",
        "reviewTimeMs",
        "promptCharacters",
        "promptTokensEstimate",
        "latencyMs",
        "costUsd"
      ],
      "properties": {
        "recall": { "$ref": "#/$defs/ratio" },
        "precision": { "$ref": "#/$defs/ratio" },
        "retentionClassification": { "$ref": "#/$defs/ratio" },
        "invention": {
          "type": "object",
          "additionalProperties": false,
          "required": ["count", "rate"],
          "properties": {
            "count": { "$ref": "#/$defs/nonnegativeNumber" },
            "rate": { "$ref": "#/$defs/ratio" }
          }
        },
        "empty": { "type": "boolean" },
        "malformed": { "type": "boolean" },
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["uniqueDimensions", "completeness", "outcomeMatch"],
          "properties": {
            "uniqueDimensions": { "$ref": "#/$defs/nonnegativeNumber" },
            "completeness": { "$ref": "#/$defs/ratio" },
            "outcomeMatch": { "$ref": "#/$defs/ratio" }
          }
        },
        "reviewTimeMs": { "$ref": "#/$defs/nonnegativeNumber" },
        "promptCharacters": { "$ref": "#/$defs/nonnegativeNumber" },
        "promptTokensEstimate": { "$ref": "#/$defs/nonnegativeNumber" },
        "latencyMs": { "$ref": "#/$defs/nonnegativeNumber" },
        "costUsd": { "$ref": "#/$defs/nonnegativeNumber" }
      }
    },
    "floors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "completeDeclaredSourceInclusion",
        "sixUniqueCoverageRows",
        "zeroAutomaticWrites",
        "zeroProjectStoreWrites",
        "zeroInventedEstablishedItems",
        "allSeededChangesAccounted",
        "boundedRequestPolicy",
        "passed"
      ],
      "properties": {
        "completeDeclaredSourceInclusion": { "type": "boolean" },
        "sixUniqueCoverageRows": { "type": "boolean" },
        "zeroAutomaticWrites": { "type": "boolean" },
        "zeroProjectStoreWrites": { "type": "boolean" },
        "zeroInventedEstablishedItems": { "type": "boolean" },
        "allSeededChangesAccounted": { "type": "boolean" },
        "boundedRequestPolicy": { "type": "boolean" },
        "passed": { "type": "boolean" }
      }
    },
    "aggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocolPlanComplete",
        "actualRequestCount",
        "actualCostUsd",
        "emptyFrequency",
        "malformedFrequency",
        "averages",
        "byWorkflow"
      ],
      "properties": {
        "protocolPlanComplete": { "type": "boolean" },
        "actualRequestCount": { "type": "integer", "minimum": 0, "maximum": 16 },
        "actualCostUsd": { "$ref": "#/$defs/nonnegativeNumber" },
        "emptyFrequency": { "$ref": "#/$defs/ratio" },
        "malformedFrequency": { "$ref": "#/$defs/ratio" },
        "averages": { "$ref": "#/$defs/averages" },
        "byWorkflow": {
          "type": "object",
          "additionalProperties": false,
          "required": ["old", "new"],
          "properties": {
            "old": { "$ref": "#/$defs/workflowAggregate" },
            "new": { "$ref": "#/$defs/workflowAggregate" }
          }
        }
      }
    },
    "averages": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recall",
        "precision",
        "retentionClassification",
        "inventionRate",
        "coverageCompleteness",
        "coverageOutcomeMatch",
        "reviewTimeMs",
        "promptCharacters",
        "promptTokensEstimate",
        "latencyMs",
        "costUsd"
      ],
      "properties": {
        "recall": { "$ref": "#/$defs/ratio" },
        "precision": { "$ref": "#/$defs/ratio" },
        "retentionClassification": { "$ref": "#/$defs/ratio" },
        "inventionRate": { "$ref": "#/$defs/ratio" },
        "coverageCompleteness": { "$ref": "#/$defs/ratio" },
        "coverageOutcomeMatch": { "$ref": "#/$defs/ratio" },
        "reviewTimeMs": { "$ref": "#/$defs/nonnegativeNumber" },
        "promptCharacters": { "$ref": "#/$defs/nonnegativeNumber" },
        "promptTokensEstimate": { "$ref": "#/$defs/nonnegativeNumber" },
        "latencyMs": { "$ref": "#/$defs/nonnegativeNumber" },
        "costUsd": { "$ref": "#/$defs/nonnegativeNumber" }
      }
    },
    "workflowAggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requestCount", "totalCostUsd"],
      "properties": {
        "requestCount": { "type": "integer", "minimum": 0, "maximum": 8 },
        "totalCostUsd": { "$ref": "#/$defs/nonnegativeNumber" }
      }
    },
    "stewardReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "steward", "decision", "recordedAt", "rationale"],
      "properties": {
        "status": { "enum": ["not-recorded", "recorded"] },
        "steward": { "type": ["string", "null"] },
        "decision": { "enum": ["GO", "NO-GO", null] },
        "recordedAt": { "type": ["string", "null"] },
        "rationale": { "type": ["string", "null"] }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "not-recorded" } } },
          "then": {
            "properties": {
              "steward": { "type": "null" },
              "decision": { "type": "null" },
              "recordedAt": { "type": "null" },
              "rationale": { "type": "null" }
            }
          },
          "else": {
            "properties": {
              "steward": { "type": "string", "minLength": 1 },
              "decision": { "enum": ["GO", "NO-GO"] },
              "recordedAt": { "type": "string", "format": "date-time" },
              "rationale": { "type": "string", "minLength": 1 }
            }
          }
        }
      ]
    }
  }
}
